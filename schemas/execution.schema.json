{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "summary", "changed_files", "checks_run"],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "passed"],
        "properties": {
          "command": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
