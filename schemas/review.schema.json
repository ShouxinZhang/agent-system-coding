{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "approved", "issues"],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "approved": {
      "type": "boolean"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
